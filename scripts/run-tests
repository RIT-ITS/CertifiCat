docker network create --driver bridge certificat_test &>/dev/null || true

wait-for() {
  local svc="$1"
  local cnt=20
  local out=""
  
  echo -n "Waiting for $1"
  until [ "$cnt" -eq 0 ]; do
    sleep 1
    echo -n "."
    
    set +e
    out="$("${@:2}")"
    if [ "$?" -eq 0 ]; then echo "done" && break; fi
    set -e

    ((cnt--))
  done

  if [ "$cnt" -eq 0 ]; then
    echo -e "timeout.\nLast output: $out"
    exit 1
  fi
}

create-redis-container() {
  local name="tmpredis"
  docker rm -f "$name" &>/dev/null || true
  echo -n "Creating redis container..."
  docker run --name "$name" --network certificat_test -d redis:latest --requirepass password
}

create-mariadb-container() {
  local name="tmpmariadb"
  docker rm -f "$name" &>/dev/null || true
  echo -n "Creating maraidb container..."
  docker run --rm --name "$name" --network certificat_test -d -e MARIADB_DATABASE=certificat -e MARIADB_ROOT_PASSWORD=root mariadb:latest

  wait-for "mariadb container" docker exec -it "$name" mariadb -h localhost -proot --skip-ssl -e "select 'success'"
}

create-postgres-container() {
  local name="tmppostgres"
  docker rm -f "$name" &>/dev/null || true
  echo -n "Creating postgres container..."
  docker run --rm --name "$name" --network certificat_test -d -e POSTGRES_PASSWORD=root postgres

  wait-for "postgres container" docker exec -it $name psql -U postgres -o /tmp/results -Atqc "select 1;"
}

run-tests() {
  docker run --network certificat_test \
    -e CERTIFICAT__CONFIG=/etc/certificat/config.yml \
    --mount "type=bind,source=${CONFIG_FILE},target=/etc/certificat/config.yml" \
    --mount "type=bind,source=${ROOT}/,target=/workspaces/certificat" \
    --user 1000 \
    -it "${TAG}" bash -c '. $HOME/.local/bin/env && /workspaces/certificat/scripts/omnidev test'
}

create-redis-container

create-mariadb-container
DB_TYPE="mysql" DB_HOST="tmpmariadb." write-config
run-tests

create-postgres-container
DB_TYPE="postgresql" DB_HOST="tmppostgres." DB_USER="postgres" write-config
run-tests


