set -euo pipefail

HERE="$(dirname "$(readlink -f "$0")")"
ROOT="$(realpath ${HERE}/../)"
TAG="certificat:test-runner"

docker buildx build \
    -f "${ROOT}/.devcontainer/Dockerfile" . --tag "${TAG}"

CONFIG_FILE="$(mktemp)"
>$CONFIG_FILE
# shellcheck disable=SC2086
